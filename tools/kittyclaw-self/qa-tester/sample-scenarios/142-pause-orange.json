{
  "setup": [
    { "type": "createProject", "name": "qa-test", "workspacePath": "D:/Sources/Ekioo/Todo" },
    { "type": "togglePause", "project": "qa-test" }
  ],
  "actions": [
    { "type": "navigate", "url": "/" },
    { "type": "wait", "ms": 500 },
    { "type": "screenshot", "name": "home-paused", "description": "Home page card with project in paused state" },
    { "type": "assertCss",
      "selector": ".project-card-wrap.project-paused .project-pause-btn",
      "property": "color",
      "expected": "rgb(245, 158, 11)" },

    { "type": "click", "selector": ".project-card-wrap.project-paused" },
    { "type": "wait", "ms": 500 },
    { "type": "screenshot", "name": "board-paused", "description": "Board header pause button" },
    { "type": "assertCss",
      "selector": ".pause-btn--paused",
      "property": "color",
      "expected": "rgb(245, 158, 11)" }
  ],
  "verdict": { "passOn": "all-asserts-pass" }
}
