{
  "automations": [
    {
      "id": "assignee-dispatch",
      "name": "Dispatch: Todo ticket -> InProgress + run assigned agent",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 30,
        "columns": [
          "Todo"
        ],
        "debounceSeconds": 0
      },
      "conditions": [
        {
          "type": "assignedTo",
          "slugs": [
            "programmer",
            "producer",
            "qa-tester",
            "groomer",
            "committer",
            "code-janitor",
            "evaluator"
          ]
        },
        {
          "type": "ticketCountInColumn",
          "columns": [
            "InProgress"
          ],
          "sameAssignee": true,
          "operator": "==",
          "value": 0
        }
      ],
      "actions": [
        {
          "type": "moveTicketStatus",
          "to": "InProgress"
        },
        {
          "type": "runAgent",
          "agent": "{assignee}",
          "concurrencyGroup": "{assignee}",
          "maxTurns": 100,
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "{assignee}"
        }
      ]
    },
    {
      "id": "groomer",
      "name": "Groomer: enrich Backlog tickets assigned to groomer",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 30,
        "columns": [
          "Backlog"
        ],
        "assigneeSlug": "groomer",
        "debounceSeconds": 0
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "groomer",
          "maxTurns": 100,
          "concurrencyGroup": "groomer",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-haiku-4-5",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "groomer"
        }
      ]
    },
    {
      "id": "committer-on-done",
      "name": "Committer: commit changes when a ticket reaches Done",
      "enabled": true,
      "trigger": {
        "type": "statusChange",
        "pollSeconds": 30,
        "to": "Done"
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "committer",
          "maxTurns": 50,
          "concurrencyGroup": "git",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "committer"
        }
      ]
    },
    {
      "id": "producer-on-subtick",
      "name": "Producer: re-dispatch when sub-tickets change",
      "enabled": true,
      "trigger": {
        "type": "subTicketStatus",
        "pollSeconds": 30,
        "parentColumn": "InProgress"
      },
      "conditions": [
        {
          "type": "assignedTo",
          "slugs": [
            "producer"
          ]
        }
      ],
      "actions": [
        {
          "type": "runAgent",
          "agent": "producer",
          "maxTurns": 50,
          "concurrencyGroup": "producer",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "producer"
        }
      ]
    },
    {
      "id": "evaluator-on-done",
      "name": "Evaluator: score tickets that reach Done",
      "enabled": true,
      "trigger": {
        "type": "statusChange",
        "pollSeconds": 30,
        "to": "Done"
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "evaluator",
          "maxTurns": 50,
          "concurrencyGroup": "evaluator",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "evaluator"
        }
      ]
    },
    {
      "id": "code-janitor-nightly",
      "name": "Code Janitor: periodic codebase hygiene",
      "enabled": true,
      "trigger": {
        "type": "interval",
        "seconds": 86400
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "code-janitor",
          "maxTurns": 150,
          "concurrencyGroup": "code-janitor",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-haiku-4-5",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "code-janitor"
        }
      ]
    },
    {
      "id": "auto-review-on-all-subs-done",
      "name": "Parent to Review when all sub-tickets are Done",
      "enabled": true,
      "trigger": {
        "type": "subTicketStatus",
        "pollSeconds": 30,
        "parentColumn": "InProgress"
      },
      "conditions": [
        {
          "type": "allSubTicketsInStatus",
          "statuses": [
            "Done"
          ],
          "negate": false
        }
      ],
      "actions": [
        {
          "type": "moveTicketStatus",
          "to": "Review"
        },
        {
          "type": "addComment",
          "content": "Tous les sous-tickets sont en Done. Parent deplace en Review automatiquement.",
          "author": "system"
        }
      ]
    },
    {
      "id": "programmer-run",
      "name": "Programmer: resume on InProgress tickets",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 30,
        "columns": [
          "InProgress"
        ],
        "assigneeSlug": "programmer",
        "debounceSeconds": 0
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "programmer",
          "concurrencyGroup": "programmer",
          "maxTurns": 200,
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": false
        },
        {
          "type": "commitAgentMemory",
          "agent": "programmer"
        }
      ]
    },
    {
      "id": "qa-on-review",
      "name": "QA: validate work moved to Review",
      "enabled": true,
      "trigger": {
        "type": "statusChange",
        "pollSeconds": 30,
        "to": "Review"
      },
      "conditions": [
        {
          "type": "assignedTo",
          "slugs": [
            "programmer"
          ]
        }
      ],
      "actions": [
        {
          "type": "runAgent",
          "agent": "qa-tester",
          "maxTurns": 100,
          "concurrencyGroup": "qa-tester",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": false
        },
        {
          "type": "commitAgentMemory",
          "agent": "qa-tester"
        }
      ]
    },
    {
      "id": "weekly-ticket-example",
      "name": "Example: create a weekly review ticket every Monday",
      "enabled": false,
      "trigger": {
        "type": "interval",
        "cron": "0 9 * * MON"
      },
      "conditions": [],
      "actions": [
        {
          "type": "createTicket",
          "title": "Weekly review {monday}",
          "description": "Automated weekly review ticket for the week starting {monday}.",
          "status": "Todo",
          "priority": "NiceToHave",
          "createdBy": "automation",
          "skipIfExists": true
        }
      ]
    },
    {
      "id": "owner-feedback",
      "name": "Owner feedback: re-dispatch assignee when owner comments",
      "enabled": true,
      "trigger": {
        "type": "ticketCommentAdded",
        "pollSeconds": 30,
        "authors": [
          "owner"
        ]
      },
      "conditions": [
        {
          "type": "assignedTo",
          "slugs": [
            "programmer",
            "producer",
            "qa-tester",
            "groomer",
            "committer",
            "code-janitor",
            "evaluator"
          ]
        },
        {
          "type": "ticketInColumn",
          "columns": [
            "Todo",
            "InProgress",
            "Blocked"
          ]
        }
      ],
      "actions": [
        {
          "type": "runAgent",
          "agent": "{assignee}",
          "concurrencyGroup": "{assignee}",
          "maxTurns": 100,
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": false
        },
        {
          "type": "commitAgentMemory",
          "agent": "{assignee}"
        }
      ]
    }
  ]
}